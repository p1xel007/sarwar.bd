---
export interface Props {
  type: "BlogPosting" | "Person" | "WebSite";
  data: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === "BlogPosting") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.description,
    author: {
      "@type": "Person",
      name: data.author || "Sarwar Alam",
      url: "https://sarwar.bd/about",
    },
    datePublished: data.pubDatetime.toISOString(),
    dateModified: data.modDatetime?.toISOString() || data.pubDatetime.toISOString(),
    publisher: {
      "@type": "Person",
      name: "Sarwar Alam",
      logo: {
        "@type": "ImageObject",
        url: "https://sarwar.bd/sarwar-avatar.jpg",
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": data.url,
    },
    image: data.ogImage || "https://sarwar.bd/sarwar-avatar.jpg",
    articleSection: data.tags?.[0] || "Technology",
    keywords: data.tags?.join(", ") || "",
    wordCount: data.wordCount,
    timeRequired: data.readingTime,
  };
} else if (type === "Person") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Sarwar Alam",
    url: "https://sarwar.bd",
    image: "https://sarwar.bd/sarwar-avatar.jpg",
    sameAs: [
      "https://github.com/p1xel007",
      "https://twitter.com/sarwaralambd",
      "https://www.linkedin.com/in/sarwar-dev/",
    ],
    jobTitle: "Full Stack Developer & Team Lead",
    description:
      "Full Stack Developer & Team Lead. 8+ years building lead distribution systems, SaaS platforms, and scalable web applications.",
  };
} else if (type === "WebSite") {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Sarwar Alam",
    url: "https://sarwar.bd",
    description:
      "Full Stack Developer & Team Lead. 8+ years building lead distribution systems, SaaS platforms, and scalable web applications.",
    author: {
      "@type": "Person",
      name: "Sarwar Alam",
    },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://sarwar.bd/search?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
